<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to list and scan all installed packages -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <!-- Required by Shizuku to apply settings and revoke permissions -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <!-- Required to read per-app usage/network stats -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- Required to restart guardian service on boot and detect OTA -->
    <uses-permission android:name="android.intent.action.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Required for WorkManager foreground service (Android 9+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Required to post guardian alerts and threat notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required for sensor monitoring (mic/camera detection) — grant via ADB/Shizuku -->
    <uses-permission android:name="android.permission.GET_APP_OPS_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- Required for Phase 2: GuardianVPN local DNS filtering -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- BIND_VPN_SERVICE is declared on the service, not as a uses-permission -->

    <application
        android:name=".HandsOffApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HandsOff"
        android:largeHeap="true">

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.HandsOff">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Shizuku provider — required for ADB-level shell access without root -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!-- GuardianVpnService — DNS-level tracker blocker, no root required.
             The android.net.VpnService intent-filter is REQUIRED by Android to
             identify this as a VPN service during VpnService.prepare().
             exported=false: only this app can start it via explicit Intent. -->
        <service
            android:name=".service.GuardianVpnService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- SensorGuardService — mic/camera access monitoring.
             exported=false: only started by this app's BootReceiver and UI. -->
        <service
            android:name=".service.SensorGuardService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- WorkManager foreground service for background scans -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- Boot receiver — OTA fingerprint detection + service restart.
             exported=false is correct: BOOT_COMPLETED is a protected system broadcast,
             no external app should trigger this directly. -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Package watchdog — detects new permissions added by app updates.
             exported=true is required: package broadcasts are system-sent, not self-sent.
             data scheme android:scheme="package" is required to receive these intents. -->
        <receiver
            android:name=".receiver.PackageChangedReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_FULLY_REMOVED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
